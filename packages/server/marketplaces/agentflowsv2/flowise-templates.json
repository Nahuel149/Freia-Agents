                    {
                        "label": "Tool Code",
                        "name": "toolCode",
                        "type": "code",
                        "default": "// Database Connector Tool\nconst { Pool } = require('pg');\n\nclass DatabaseConnector {\n  constructor() {\n    this.pool = new Pool({\n      connectionString: process.env.POSTGRES_CONNECTION\n    });\n  }\n\n  async execute(operation, data) {\n    const client = await this.pool.connect();\n    try {\n      switch(operation) {\n        case 'getCustomer':\n          return await this.getCustomer(client, data.phoneNumber);\n        case 'upsertCustomer':\n          return await this.upsertCustomer(client, data);\n        case 'createSale':\n          return await this.createSale(client, data);\n        case 'scheduleFollowUp':\n          return await this.scheduleFollowUp(client, data);\n        default:\n          throw new Error('Operación no válida');\n      }\n    } finally {\n      client.release();\n    }\n  }\n\n  async getCustomer(client, phoneNumber) {\n    const result = await client.query(\n      'SELECT * FROM customers WHERE phone_number = $1',\n      [phoneNumber]\n    );\n    return result.rows[0] || null;\n  }\n\n  async upsertCustomer(client, customerData) {\n    const query = `\n      INSERT INTO customers (phone_number, company_name, contact_name, email, industry)\n      VALUES ($1, $2, $3, $4, $5)\n      ON CONFLICT (phone_number) DO UPDATE SET\n        company_name = EXCLUDED.company_name,\n        contact_name = EXCLUDED.contact_name,\n        email = EXCLUDED.email,\n        industry = EXCLUDED.industry,\n        updated_at = CURRENT_TIMESTAMP\n      RETURNING *\n    `;\n    const result = await client.query(query, [\n      customerData.phoneNumber,\n      customerData.companyName,\n      customerData.contactName,\n      customerData.email,\n      customerData.industry\n    ]);\n    return result.rows[0];\n  }\n}\n\nmodule.exports = DatabaseConnector;"
