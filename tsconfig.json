{
    "compilerOptions": {
        "lib": ["es2021"],
        "target": "es2021",
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "module": "commonjs",
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "strict": true,
        "skipLibCheck": true,
        "sourceMap": true,
        "strictPropertyInitialization": false,
        "declaration": true,
        "resolveJsonModule": true
    },
    "ts-node": {
        "esm": false,
        "compilerOptions": {
            "module": "commonjs"
        }
    },
    "include": ["scripts/**/*.ts", "packages/**/*.ts"],
    "exclude": ["node_modules", "dist", "packages/server/src/enterprise/**"]
}