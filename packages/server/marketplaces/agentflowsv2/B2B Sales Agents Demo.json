                  { "label": "User", "name": "user" }
                ]
              },
              { "label": "Content", "name": "content", "type": "string", "acceptVariable": true, "generateInstruction": true, "rows": 6 }
            ],
            "id": "agentAgentflow_0-input-agentMessages-array",
            "display": true
          },
          {
            "label": "Enable Memory",
            "name": "agentEnableMemory",
            "type": "boolean",
            "description": "Memoria de la conversación",
            "default": true,
            "optional": true,
            "id": "agentAgentflow_0-input-agentEnableMemory-boolean",
            "display": true
          },
          {
            "label": "Return Response As",
            "name": "agentReturnResponseAs",
            "type": "options",
            "options": [
              { "label": "User Message", "name": "userMessage" },
              { "label": "Assistant Message", "name": "assistantMessage" }
            ],
            "default": "assistantMessage",
            "id": "agentAgentflow_0-input-agentReturnResponseAs-options",
            "display": true
          }
        ],
        "inputAnchors": [],
        "inputs": {
          "agentModel": "chatOpenAI",
          "agentMessages": [
            {
              "role": "system",
              "content": "Sos un agente de ventas B2B argentino (tono rioplatense, cercano y profesional). Conocés autos, llantas, cubiertas y repuestos. PROCESO: 1) Saludá con buena onda. 2) Consultá si es cliente existente por teléfono en BD (tabla customers). Si existe, usá datos guardados (nombre, dirección habitual, método de pago). 3) Pedí medida/modelo si falta. 4) Revisá inventario en $flow.state.inventory (JSON). Si no hay stock, proponé alternativas. 5) Explicá beneficios y garantías. 6) Si dice que es caro, negociá según $flow.state.salesManual: 1er intento 5%, 2do 8%, 3ro 10% o descuento por cantidad (12% si compra 10+). 7) Para cerrar: confirmá datos del cliente, preguntá '¿envío al lugar habitual o nueva dirección?', '¿método de pago habitual o otro?'. 8) Guardá datos nuevos/actualizados en BD. 9) Si no cierra, programá follow-up según $flow.state.followUpDelayHours. Siempre claro, breve y útil."
            }
          ],
          "agentEnableMemory": true,
          "agentReturnResponseAs": "assistantMessage",
          "agentModelConfig": {
            "cache": "",
            "modelName": "gpt-4o-mini",
            "temperature": 0.3,
            "streaming": true,
            "maxTokens": "",
            "topP": "",
            "frequencyPenalty": "",
            "presencePenalty": "",
            "timeout": "",
            "strictToolCalling": "",
            "stopSequence": "",
            "basepath": "",
            "proxyUrl": "",
            "baseOptions": "",
            "allowImageUploads": "",
            "imageResolution": "low",
            "reasoningEffort": "",
            "agentModel": "chatOpenAI"
          }
        },
        "outputAnchors": [ { "id": "agentAgentflow_0-output-agentAgentflow", "label": "Agent", "name": "agentAgentflow" } ],
        "outputs": {},
        "selected": false
      },
