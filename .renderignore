# Render ignore file - excludes files from deployment
# Similar to .dockerignore but specific to Render

# Development files
.env
.env.local
.env.development
.env.test
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Testing
/coverage
/cypress/videos
/cypress/screenshots
/test
__tests__
*.test.js
*.test.ts
*.spec.js
*.spec.ts
jest.config.js
cypress.config.ts

# Development dependencies
node_modules/.cache
.turbo
.next
.nuxt
.vuepress/dist

# IDE files
.vscode
.idea
*.swp
*.swo
*~

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Git
.git
.gitignore
.gitattributes

# Documentation (optional - remove if you want docs in production)
README.md
CONTRIBUTING.md
CODE_OF_CONDUCT.md
SECURITY.md
i18n/
images/
assets/Demo.png

# Development configs
.eslintrc.js
.prettierrc
.editorconfig
nodemon.json

# Husky
.husky

# Metrics and monitoring (for development)
metrics/

# Docker files (not needed for Render)
Dockerfile
docker/
.dockerignore

# Render deployment files (keep the ones we need)
# render.yaml - keep this
# Dockerfile.render - keep this
# RENDER_DEPLOYMENT.md - optional

# Build artifacts that will be rebuilt
dist/
build/
.turbo/

# Temporary files
tmp/
temp/