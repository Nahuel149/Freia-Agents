## Freia OSS example environment
# When true (default for OSS), disables workspace/org checks.
# Enterprise/SaaS builds can set this to false to enable multi-tenant logic.
OSS_MODE=true

# Manual agent LLM fallback
MANUAL_AGENT_LLM_MODEL=gpt-4.1-mini

# Manual agent OpenAI API key (fallback to OPENAI_API_KEY if set)
MANUAL_AGENT_OPENAI_API_KEY=

# Manual agents MongoDB
MONGODB_URI=
MONGODB_DATABASE=freia

# Public manual agent rate limiting
MANUAL_AGENT_PUBLIC_RATE_LIMIT_WINDOW_MS=60000
MANUAL_AGENT_PUBLIC_RATE_LIMIT_MAX=30
MANUAL_AGENT_CHAT_LOGS_COLLECTION=store_clients_chat

# Manual agent outbound scheduler (optional)
MANUAL_AGENT_OUTBOUND_SCHEDULE_ENABLED=false
MANUAL_AGENT_OUTBOUND_TIMEZONE=America/Argentina/Buenos_Aires
MANUAL_AGENT_OUTBOUND_HOUR=9
MANUAL_AGENT_OUTBOUND_MINUTE=0
MANUAL_AGENT_OUTBOUND_AGENT_ID=quintas
